{
  "manifest_version": 3,
  "name": "AI Text Refiner",
  "description": "Refine text in any textarea or contenteditable element using OpenAI.",
  "version": "1.2",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://api.groq.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true 
    }
  ]
}